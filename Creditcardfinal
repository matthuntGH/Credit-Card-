<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Card Optimizer</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0D1117;
    --surface: #161B22;
    --surface2: #1C2333;
    --border: #30363D;
    --text: #E6EDF3;
    --muted: #8B949E;
    --chase: #58A6FF;
    --win: #00D26A;
    --amber: #F0A500;
    --prime: #FF9900;
    --danger: #F85149;
    --radius: 12px;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    padding: 0 0 60px;
  }

  header {
    background: linear-gradient(180deg, #0D1117 0%, rgba(13,17,23,0) 100%);
    padding: 32px 24px 0;
    text-align: center;
    position: relative;
  }
  header::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 600px; height: 200px;
    background: radial-gradient(ellipse at 50% 0%, rgba(88,166,255,.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--chase);
    margin-bottom: 12px;
    opacity: .8;
  }
  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -.02em;
    line-height: 1.1;
    margin-bottom: 8px;
  }
  h1 span { color: var(--win); }
  .subtitle {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 36px;
  }

  .search-section {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .search-wrap {
    position: relative;
    margin-bottom: 16px;
  }
  .search-icon {
    position: absolute;
    left: 16px; top: 50%; transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
  }
  #merchant-input {
    width: 100%;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 500;
    padding: 16px 16px 16px 48px;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  #merchant-input::placeholder { color: var(--muted); font-weight: 400; }
  #merchant-input:focus {
    border-color: var(--chase);
    box-shadow: 0 0 0 3px rgba(88,166,255,.12);
  }

  #suggestions {
    position: absolute;
    top: calc(100% + 6px); left: 0; right: 0;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    z-index: 100;
    display: none;
    box-shadow: 0 16px 40px rgba(0,0,0,.5);
  }
  #suggestions.open { display: block; }
  .sug-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    cursor: pointer;
    transition: background .12s;
    font-size: 14px;
  }
  .sug-item:hover, .sug-item.active { background: rgba(88,166,255,.1); }
  .sug-icon { font-size: 18px; width: 24px; text-align: center; flex-shrink: 0; }
  .sug-name { font-weight: 500; color: var(--text); }
  .sug-cat { color: var(--muted); font-size: 12px; margin-left: auto; }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
  }
  .pill {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 99px;
    color: var(--muted);
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    cursor: pointer;
    transition: all .15s;
    white-space: nowrap;
  }
  .pill:hover { border-color: var(--chase); color: var(--chase); }
  .pill.active {
    background: rgba(88,166,255,.15);
    border-color: var(--chase);
    color: var(--chase);
  }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .winner-section {
    margin-bottom: 28px;
    display: none;
  }
  .winner-section.visible { display: block; }

  .winner-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--win);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .winner-label::before {
    content: '';
    display: inline-block;
    width: 6px; height: 6px;
    background: var(--win);
    border-radius: 50%;
    animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: .5; transform: scale(1.4); }
  }

  .winner-card {
    background: var(--surface);
    border: 1.5px solid var(--win);
    border-radius: var(--radius);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 0 32px rgba(0,210,106,.1), inset 0 1px 0 rgba(255,255,255,.04);
    position: relative;
    overflow: hidden;
  }
  .winner-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,210,106,.6), transparent);
  }
  .winner-emoji { font-size: 36px; line-height: 1; }
  .winner-info { flex: 1; min-width: 0; }
  .winner-card-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 3px;
  }
  .winner-card-detail { color: var(--muted); font-size: 13px; }
  .winner-rate {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--win);
    white-space: nowrap;
  }
  .winner-rate span { font-size: 14px; font-weight: 500; color: var(--muted); display: block; text-align: right; }

  .amount-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .amount-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .amount-prefix {
    position: absolute;
    left: 14px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--muted);
  }
  #amount-input {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 600;
    padding: 13px 16px 13px 32px;
    width: 180px;
    outline: none;
    transition: border-color .2s;
  }
  #amount-input:focus { border-color: var(--chase); }
  .amount-label { color: var(--muted); font-size: 14px; }

  .ranked-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 40px; }

  .rank-row {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 18px;
    display: grid;
    grid-template-columns: 28px 1fr auto auto;
    align-items: center;
    gap: 14px;
    transition: border-color .2s, transform .15s;
    position: relative;
    overflow: hidden;
  }
  .rank-row.top {
    border-color: var(--win);
    box-shadow: 0 0 18px rgba(0,210,106,.08);
  }
  .rank-row.top::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--win);
    border-radius: 2px 0 0 2px;
  }

  .rank-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--muted);
    text-align: center;
  }
  .rank-row.top .rank-num { color: var(--win); }

  .rank-info { min-width: 0; }
  .rank-name {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bar-wrap {
    height: 4px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
    width: 100%;
    max-width: 220px;
  }
  .bar-fill {
    height: 100%;
    border-radius: 99px;
    background: var(--muted);
    transition: width .5s cubic-bezier(.4,0,.2,1);
  }
  .rank-row.top .bar-fill { background: var(--win); }

  .rank-mult {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--muted);
    white-space: nowrap;
    text-align: right;
  }
  .rank-row.top .rank-mult { color: var(--win); }

  .rank-earn {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    white-space: nowrap;
    text-align: right;
    min-width: 80px;
  }
  .rank-row.top .rank-earn { color: var(--text); }

  .section-head {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px;
  }

  .port-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px;
    transition: border-color .2s, transform .2s, box-shadow .2s;
    cursor: default;
    position: relative;
    overflow: hidden;
  }
  .port-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    opacity: 0;
    transition: opacity .2s;
  }
  .port-card.chase::before { background: linear-gradient(90deg, #58A6FF, #1F6FEB); }
  .port-card.prime::before { background: linear-gradient(90deg, #FF9900, #F0A500); }
  .port-card.winner {
    border-color: var(--win);
    box-shadow: 0 0 24px rgba(0,210,106,.12);
  }
  .port-card.winner::before { opacity: 1; background: linear-gradient(90deg, var(--win), #00FF88) !important; }

  .port-issuer {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .port-card.chase .port-issuer { color: var(--chase); }
  .port-card.prime .port-issuer { color: var(--prime); }
  .port-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 14px;
  }
  .port-perks { display: flex; flex-direction: column; gap: 4px; }
  .port-perk {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
  }
  .port-perk strong { color: var(--text); font-weight: 600; }
  .best-badge {
    position: absolute;
    top: 10px; right: 10px;
    background: var(--win);
    color: #000;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 99px;
    display: none;
  }
  .port-card.winner .best-badge { display: block; }

  .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: var(--muted);
  }
  .empty-state .big { font-size: 40px; margin-bottom: 12px; }
  .empty-state p { font-size: 15px; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  @media (max-width: 600px) {
    .rank-row { grid-template-columns: 24px 1fr auto; }
    .rank-earn { display: none; }
    .portfolio-grid { grid-template-columns: 1fr 1fr; }
    .winner-rate { font-size: 22px; }
  }
</style>
</head>
