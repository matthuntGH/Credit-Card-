  { name: "Spotify", icon: '🎵', cat: 'streaming' },
  { name: "Apple Music", icon: '🎵', cat: 'streaming' },
  { name: "YouTube Premium", icon: '▶️', cat: 'streaming' },
  { name: "Amazon Prime Video", icon: '📦', cat: 'streaming' },
  { name: "Twitch", icon: '🎮', cat: 'streaming' },
  { name: "CVS", icon: '💊', cat: 'drugstore' },
  { name: "Walgreens", icon: '💊', cat: 'drugstore' },
  { name: "Rite Aid", icon: '💊', cat: 'drugstore' },
  { name: "CVS Pharmacy", icon: '💊', cat: 'drugstore' },
  { name: "Apple Store", icon: '🍎', cat: 'general' },
  { name: "Best Buy", icon: '💻', cat: 'general' },
  { name: "Home Depot", icon: '🏠', cat: 'general' },
  { name: "Lowe's", icon: '🔨', cat: 'general' },
];

const CAT_LABELS = {
  dining: 'Dining', travel: 'Travel', groceries: 'Groceries',
  amazon: 'Amazon', wholeFoods: 'Whole Foods / Amazon',
  gas: 'Gas', streaming: 'Streaming', drugstore: 'Drugstore', general: 'General',
};
const CAT_ICONS = {
  dining: '🍽', travel: '✈️', groceries: '🛒', amazon: '📦',
  wholeFoods: '🌿', gas: '⛽', streaming: '📺', drugstore: '💊', general: '💳',
};

let currentCat = null;
let activeSugIdx = -1;

buildPortfolio();
renderEmpty();

const input = document.getElementById('merchant-input');
const sugBox = document.getElementById('suggestions');

input.addEventListener('input', () => {
  const q = input.value.trim().toLowerCase();
  activeSugIdx = -1;
  if (!q) { closeSuggestions(); if (!currentCat) renderEmpty(); return; }
  const matches = MERCHANTS.filter(m => m.name.toLowerCase().includes(q)).slice(0, 8);
  if (!matches.length) { closeSuggestions(); return; }
  sugBox.innerHTML = matches.map((m, i) =>
    `<div class="sug-item" data-idx="${i}" data-cat="${m.cat}" data-name="${m.name}" data-icon="${m.icon}">
      <span class="sug-icon">${m.icon}</span>
      <span class="sug-name">${highlightMatch(m.name, q)}</span>
      <span class="sug-cat">${CAT_LABELS[m.cat] || m.cat}</span>
    </div>`
  ).join('');
  sugBox.classList.add('open');
  sugBox.querySelectorAll('.sug-item').forEach(el => {
    el.addEventListener('mousedown', e => {
      e.preventDefault();
      selectMerchant(el.dataset.cat, el.dataset.name, el.dataset.icon);
    });
  });
});

input.addEventListener('keydown', e => {
  const items = sugBox.querySelectorAll('.sug-item');
  if (e.key === 'ArrowDown') { e.preventDefault(); activeSugIdx = Math.min(activeSugIdx + 1, items.length - 1); updateActiveSug(items); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); activeSugIdx = Math.max(activeSugIdx - 1, -1); updateActiveSug(items); }
  else if (e.key === 'Enter') {
    if (activeSugIdx >= 0 && items[activeSugIdx]) {
      const el = items[activeSugIdx];
      selectMerchant(el.dataset.cat, el.dataset.name, el.dataset.icon);
    } else {
      const first = MERCHANTS.find(m => m.name.toLowerCase().includes(input.value.trim().toLowerCase()));
      if (first) selectMerchant(first.cat, first.name, first.icon);
    }
  } else if (e.key === 'Escape') { closeSuggestions(); }
});

document.addEventListener('click', e => { if (!e.target.closest('.search-wrap')) closeSuggestions(); });
document.getElementById('amount-input').addEventListener('input', () => { if (currentCat) renderRankedList(currentCat); });

document.querySelectorAll('.pill').forEach(pill => {
  pill.addEventListener('click', () => {
    const cat = pill.dataset.cat;
    document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    input.value = '';
    currentCat = cat;
    renderResults(cat, CAT_LABELS[cat], CAT_ICONS[cat]);
  });
});

function updateActiveSug(items) { items.forEach((el, i) => el.classList.toggle('active', i === activeSugIdx)); }
function closeSuggestions() { sugBox.classList.remove('open'); sugBox.innerHTML = ''; activeSugIdx = -1; }
function highlightMatch(name, q) {
  const idx = name.toLowerCase().indexOf(q);
  if (idx === -1) return name;
  return name.slice(0, idx) + `<strong style="color:var(--text)">${name.slice(idx, idx + q.length)}</strong>` + name.slice(idx + q.length);
}
function selectMerchant(cat, name, icon) {
  currentCat = cat;
  input.value = name;
  closeSuggestions();
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  renderResults(cat, name, icon);
}
function getRateForCard(card, cat) { return card.rewards[cat] ?? card.defaultRate; }
function renderEmpty() {
  document.getElementById('winner-section').classList.remove('visible');
  document.getElementById('results-section').style.display = 'none';
  document.getElementById('empty-state').style.display = 'block';
}
function renderResults(cat, label, icon) {
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('results-section').style.display = 'block';
  const sorted = [...CARDS].sort((a, b) => getRateForCard(b, cat) - getRateForCard(a, cat));
  const winner = sorted[0];
  document.getElementById('winner-section').classList.add('visible');
  document.getElementById('winner-label').innerHTML = `Best card for — ${icon} ${label}`;
  document.getElementById('winner-emoji').textContent = winner.emoji;
  document.getElementById('winner-name').textContent = winner.name;
  const rate = getRateForCard(winner, cat);
  if (winner.type === 'cashback') {
    document.getElementById('winner-rate-val').textContent = `${rate}%`;
    document.getElementById('winner-rate-type').textContent = 'cash back';
    document.getElementById('winner-detail').textContent = `${rate}% cash back on ${label}`;
  } else {
    document.getElementById('winner-rate-val').textContent = `${rate}×`;
    document.getElementById('winner-rate-type').textContent = 'points per $1';
    document.getElementById('winner-detail').textContent = `${rate}× points on ${label}`;
  }
  renderRankedList(cat);
  updatePortfolioWinner(winner.id);
}
function renderRankedList(cat) {
  const amount = parseFloat(document.getElementById('amount-input').value) || 0;
  const sorted = [...CARDS].sort((a, b) => getRateForCard(b, cat) - getRateForCard(a, cat));
  const maxRate = getRateForCard(sorted[0], cat);
  document.getElementById('ranked-list').innerHTML = sorted.map((card, i) => {
    const rate = getRateForCard(card, cat);
    const pct = (rate / maxRate) * 100;
    const isTop = i === 0;
    const earnLabel = card.type === 'cashback'
      ? `$${(amount * rate / 100).toFixed(2)}`
      : `${Math.round(amount * rate).toLocaleString()} pts`;
    const rateLabel = card.type === 'cashback' ? `${rate}%` : `${rate}×`;
    return `<div class="rank-row${isTop ? ' top' : ''}">
      <div class="rank-num">${i + 1}</div>
      <div class="rank-info">
        <div class="rank-name">${card.shortName}</div>
        <div class="bar-wrap"><div class="bar-fill" style="width:${pct}%"></div></div>
      </div>
      <div class="rank-mult">${rateLabel}</div>
      <div class="rank-earn">${earnLabel}</div>
    </div>`;
  }).join('');
}
function buildPortfolio() {
  document.getElementById('portfolio-grid').innerHTML = CARDS.map(card => `
    <div class="port-card ${card.cssClass}" id="port-${card.id}">
      <div class="best-badge">Best pick</div>
      <div class="port-issuer">${card.issuer}</div>
      <div class="port-name">${card.shortName}</div>
      <div class="port-perks">${card.perks.map(([label]) => `<div class="port-perk"><span>${label}</span></div>`).join('')}</div>
    </div>`).join('');
}
function updatePortfolioWinner(winnerId) {
  document.querySelectorAll('.port-card').forEach(el => el.classList.remove('winner'));
  document.getElementById(`port-${winnerId}`)?.classList.add('winner');
}
</script>
</body>
</html>
